@page "/activity/{Id:guid}"
@using ActivitiesApp.Shared.Models
@using ActivitiesApp.Shared.Services
@using Microsoft.JSInterop
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization

<div class="detail-page">
    @if (activity == null)
    {
        <div class="loading">Loading activity...</div>
    }
    else
    {
        <div class="detail-top-bar">
            <button class="back-button" @onclick="GoBack">Back</button>
            @if (_isOwner)
            {
                <div class="owner-actions">
                    <button class="btn btn-outline-primary btn-sm" @onclick="EditActivity">Edit</button>
                    @if (_confirmingDelete)
                    {
                        <span class="delete-confirm">
                            Delete this activity?
                            <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete" disabled="@_deleting">
                                @(_deleting ? "Deleting..." : "Yes, delete")
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => _confirmingDelete = false">Cancel</button>
                        </span>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => _confirmingDelete = true">Delete</button>
                    }
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="alert alert-danger mt-2">@_actionError</div>
        }

        <div class="detail-card">
            <div class="detail-image">
                @if (!string.IsNullOrEmpty(activity.ImageUrl))
                {
                    <img src="@activity.ImageUrl" alt="@activity.Name" />
                }
                else
                {
                    <div class="image-placeholder detail">
                        <span>No Image Available</span>
                    </div>
                }
            </div>

            <div class="detail-content">
                <div class="detail-header">
                    <h1>@activity.Name</h1>
                    @if (!string.IsNullOrEmpty(activity.Category))
                    {
                        <span class="detail-category">@activity.Category</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(activity.CreatedByUserId))
                {
                    <div class="detail-creator">
                        @if (!string.IsNullOrEmpty(activity.CreatedByProfilePictureUrl))
                        {
                            <img src="@activity.CreatedByProfilePictureUrl" alt="@activity.CreatedByDisplayName" class="creator-avatar" />
                        }
                        else
                        {
                            <div class="creator-avatar creator-avatar-fallback">
                                @(string.IsNullOrWhiteSpace(activity.CreatedByDisplayName) ? "?" : activity.CreatedByDisplayName[0].ToString().ToUpper())
                            </div>
                        }
                        <span class="creator-name">@(activity.CreatedByDisplayName ?? "Community Member")</span>
                    </div>
                }

                <div class="detail-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starIndex = i;
                        <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                    }
                    <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                </div>

                <div class="detail-info-grid">
                    <div class="info-item">
                        <span class="info-label">Cost</span>
                        <span class="info-value">@(activity.Cost == 0 ? "Free" : $"${activity.Cost:F2}")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">City</span>
                        <span class="info-value">@activity.City</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Distance</span>
                        <span class="info-value">--</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Date & Time</span>
                        <span class="info-value">@activity.Activitytime.ToString("MMM d, yyyy h:mm tt")</span>
                    </div>
                </div>

                <div class="age-range-banner">
                    Ideal for ages @activity.MinAge - @activity.MaxAge
                </div>

                <div class="detail-description">
                    <h3>About this Activity</h3>
                    <p>@(string.IsNullOrEmpty(activity.Description) ? "No description available." : activity.Description)</p>
                </div>

                <div class="detail-location">
                    <h3>Location</h3>
                    <p>@activity.City</p>
                    <p class="coords">@activity.Latitude.ToString("0.0000"), @activity.Longitude.ToString("0.0000")</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Activity? activity;
    private bool _isOwner;
    private bool _confirmingDelete;
    private bool _deleting;
    private string? _actionError;

    protected override async Task OnInitializedAsync()
    {
        activity = await ActivityService.GetActivityAsync(Id);

        if (!string.IsNullOrEmpty(activity?.CreatedByUserId))
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var oid = auth.User.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
                   ?? auth.User.FindFirst("oid")?.Value;
            _isOwner = oid == activity.CreatedByUserId;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("addRecentlyViewed", Id.ToString());
    }

    private void EditActivity() => Navigation.NavigateTo($"/activity/{Id}/edit");

    private async Task ConfirmDelete()
    {
        _deleting = true;
        _actionError = null;
        try
        {
            await ActivityService.DeleteActivityAsync(Id);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
            _confirmingDelete = false;
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}
