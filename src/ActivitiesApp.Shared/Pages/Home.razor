@page "/"
@using ActivitiesApp.Shared.Services
@using ActivitiesApp.Shared.Models
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject ILogger<Home> Logger
@inject LocationService LocationService
@implements IDisposable

<PageTitle>Home</PageTitle>

<div class="home-page">
    <!-- Location Row -->
    <div class="home-location-row">
        <h1 class="home-title">Discover</h1>
        <div class="location-icon-wrapper">
            <button class="location-btn @(hasActiveLocation ? "active" : "")" @onclick="ToggleLocationPopup" title="Your location">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/>
                    <path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
                </svg>
            </button>
            @if (showLocationPopup)
            {
                <div class="location-popup">
                    @if (hasLocation)
                    {
                        @if (!string.IsNullOrEmpty(userAddress))
                        {
                            <p class="location-address">@userAddress</p>
                        }
                        else
                        {
                            <p class="location-address loading-text">Looking up address...</p>
                        }
                        <p class="location-coords">@userLat.ToString("0.0000"), @userLng.ToString("0.0000")</p>
                    }
                    else
                    {
                        <p class="location-address">GPS not available</p>
                    }
                    <div class="location-popup-edit">
                        <input class="zip-input" placeholder="Enter ZIP code" maxlength="5"
                               @bind="locationInput" @bind:event="oninput" @onkeyup="OnLocationInputKeyUp" />
                        <button class="zip-btn" @onclick="ApplyManualLocationAsync">Apply</button>
                    </div>
                    @if (locationError != null)
                    {
                        <p class="location-error" style="color:red;font-size:0.85em;margin:4px 0;">@locationError</p>
                    }
                    @if (hasManualLocation && hasLocation)
                    {
                        <button class="zip-btn" style="margin-top:6px;width:100%;" @onclick="UseCurrentLocation">Use Current Location</button>
                    }
                    @if (hasManualLocation)
                    {
                        <p class="location-override-label">Using: @LocationService.ManualLocationLabel</p>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Search Bar -->
    <div class="search-container">
        <input type="text" class="search-input" placeholder="Search activities..."
               @bind="searchText" @bind:event="oninput" />
    </div>

    <!-- Quota Warning Banner -->
    @if (quotaWarningMessage != null && !quotaBannerDismissed)
    {
        <div class="quota-banner @(quotaWarningLevel)" style="padding:8px 16px;margin-bottom:12px;border-radius:8px;display:flex;align-items:center;justify-content:space-between;font-size:0.9rem;@(quotaWarningLevel == "critical" ? "background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;" : "background:#fef9c3;color:#854d0e;border:1px solid #fde047;")">
            <span>@quotaWarningMessage</span>
            <button @onclick="() => quotaBannerDismissed = true" style="background:none;border:none;cursor:pointer;font-size:1.1rem;padding:0 4px;">✕</button>
        </div>
    }

    <!-- Recently Viewed Section -->
    @if (recentActivities != null && recentActivities.Any())
    {
        <div class="home-section">
            <h2 class="home-section-title">Recently Viewed</h2>
            <div class="cards-carousel">
                @foreach (var activity in GetFilteredRecent())
                {
                    <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(activity.ImageUrl))
                            {
                                <img src="@activity.ImageUrl" alt="@activity.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <div class="image-placeholder" style="display:none;">
                                    <span>@GetFirstTagIcon(activity.Category)</span>
                                </div>
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <span>@GetFirstTagIcon(activity.Category)</span>
                                </div>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@activity.Name</h3>
                            <div class="card-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                }
                                <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                            </div>
                            <div class="card-details">
                                <span class="card-cost">@FormatCost(activity.Cost)</span>
                                <span class="card-distance">@GetDistance(activity) mi</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Tag Cards Section -->
    <div class="home-section">
        <h2 class="home-section-title">What are you looking for?</h2>
        <p class="home-section-subtitle">Tap a tag to load places near your current or selected location.</p>
        <div class="tag-cards-grid">
            @foreach (var tag in tagCards)
            {
                <div class="tag-card @(selectedTag == tag.Name ? "selected" : "")"
                     @onclick="() => OnTagSelected(tag.Name)">
                    <span class="tag-card-icon">@tag.Emoji</span>
                    <span class="tag-card-label">@tag.Name</span>
                </div>
            }
        </div>
    </div>

    <!-- Filtered Results Section -->
    @if (selectedTag != null)
    {
        <div class="home-section" id="filtered-results">
            <div class="filtered-header">
                <h2 class="home-section-title">@selectedTag</h2>
                <button class="clear-filter-btn" @onclick="ClearFilter">Clear</button>
            </div>

            @if (isLoadingFiltered)
            {
                <div class="loading">Searching nearby...</div>
            }
            else if (filteredActivities != null && !filteredActivities.Any())
            {
                <div class="no-results">No @selectedTag activities found nearby.</div>
            }
            else if (filteredActivities != null)
            {
                <div class="cards-grid">
                    @foreach (var activity in filteredActivities)
                    {
                        <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                            <div class="card-image">
                                @if (!string.IsNullOrEmpty(activity.ImageUrl))
                                {
                                    <img src="@activity.ImageUrl" alt="@activity.Name" loading="lazy"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="image-placeholder" style="display:none;">
                                        <span>@GetTagIcon(selectedTag)</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="image-placeholder">
                                        <span>@GetTagIcon(selectedTag)</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(selectedTag))
                                {
                                    <span class="card-category-badge">@selectedTag</span>
                                }
                            </div>
                            <div class="card-body">
                                <h3 class="card-title">@activity.Name</h3>
                                <div class="card-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starIndex = i;
                                        <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                    }
                                    <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                                </div>
                                <div class="card-details">
                                    <span class="card-cost">@FormatCost(activity.Cost)</span>
                                    <span class="card-distance">@GetDistance(activity) mi</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    // Tag card definitions matching GooglePlaceTagMapper on the backend
    private static readonly List<TagCardInfo> tagCards =
    [
        new("Restaurant", "\ud83c\udf7d\ufe0f"),
        new("Fast Food", "\ud83c\udf54"),
        new("Convenience Store", "\ud83c\udfe0"),
        new("Attractions", "\u2b50"),
        new("Outdoors", "\ud83c\udf32"),
        new("Arts & Culture", "\ud83c\udfa8"),
        new("Nightlife", "\ud83c\udf19"),
        new("Shopping", "\ud83d\udecd\ufe0f"),
        new("Fitness & Sports", "\ud83c\udfcb\ufe0f"),
        new("Wellness & Beauty", "\u2728"),
        new("Education", "\ud83c\udf93"),
    ];
    private string searchText = "";
    private const int HomeDiscoverRadiusMiles = 10;
    private const double MetersPerMile = 1609.34;

    private List<Activity>? recentActivities;
    private Dictionary<string, List<Activity>> cachedActivitiesByTag = new(StringComparer.OrdinalIgnoreCase);
    private List<Activity>? filteredActivities;
    private string? selectedTag;
    private bool isLoadingFiltered;
    private int cacheGeneration;
    private bool startupComplete;

    // Render stability tracking — logs how many times the displayed list changes
    private int renderCount;
    private int dataChangedCount;
    private int filteredListVersion;
    private Dictionary<Guid, string?> lastRenderedImageUrls = new();

    // Retry counter: when DataChanged fires and cached tags have empty results,
    // retry up to N times (MAUI returns stale/empty cache, background refresh brings real data).
    // Reset on location change so each new location gets fresh retries.
    private int _emptyTagRetryCount;

    // Quota warning
    private string? quotaWarningMessage;
    private string quotaWarningLevel = "warning"; // "warning" or "critical"
    private bool quotaBannerDismissed;

    // Location popup
    private bool showLocationPopup;
    private string? userAddress;
    private string locationInput = "";
    private string? locationError;

    // GPS from service
    private bool hasLocation => LocationService.HasLocation;
    private double userLat => LocationService.Latitude;
    private double userLng => LocationService.Longitude;

    // Manual + active location from shared singleton
    private bool hasManualLocation => LocationService.HasManualLocation;
    private bool hasActiveLocation => LocationService.HasActiveLocation;
    private double activeLat => LocationService.ActiveLatitude;
    private double activeLng => LocationService.ActiveLongitude;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        renderCount++;
        if (renderCount <= 5 || renderCount % 10 == 0)
        {
            Logger.LogDebug("Home render #{RenderCount}: selectedTag={Tag}, filteredCount={FilteredCount}, dataChangedCount={DataChangedCount}, listVersion={ListVersion}",
                renderCount, selectedTag ?? "<none>", filteredActivities?.Count ?? 0, dataChangedCount, filteredListVersion);
        }

        if (firstRender)
        {
            Logger.LogInformation("Home first render complete");
            LocationService.LocationChanged += OnLocationChanged;
            ActivityService.DataChanged += OnDataChanged;

            // Start location tracking
            var locationSw = System.Diagnostics.Stopwatch.StartNew();
            LocationService.StartTracking();

            // If location is already known (back-navigation, LocationService is scoped/singleton),
            // skip the 2s wait. Only wait on a true cold start.
            if (!hasActiveLocation)
            {
                var locationReady = new TaskCompletionSource<bool>();
                void onFirstLocation()
                {
                    locationReady.TrySetResult(true);
                }
                LocationService.LocationChanged += onFirstLocation;
                var winner = await Task.WhenAny(locationReady.Task, Task.Delay(2000));
                LocationService.LocationChanged -= onFirstLocation;

                Logger.LogInformation(
                    "Home startup: cold start, location resolved={Resolved} in {Ms}ms, hasActiveLocation={HasActive}, lat={Lat}, lng={Lng}",
                    winner == locationReady.Task, locationSw.ElapsedMilliseconds, hasActiveLocation, activeLat, activeLng);
            }
            else
            {
                Logger.LogInformation(
                    "Home startup: location already known, skipping wait, lat={Lat}, lng={Lng}, elapsed={Ms}ms",
                    activeLat, activeLng, locationSw.ElapsedMilliseconds);
            }

            await LoadRecentlyViewed();
            ResetTagCache("startup");
            startupComplete = true;
            Logger.LogInformation("Home startup complete: cachedTags={CachedCount}, hasLocation={HasLocation}, hasActiveLocation={HasActive}, recentlyViewedCount={RecentCount}",
                cachedActivitiesByTag.Count, hasLocation, hasActiveLocation, recentActivities?.Count ?? 0);
            // Background warm removed to reduce Google API costs — tags load on-demand when clicked
            _ = CheckQuotaStatusAsync();
        }
    }

    private async void OnLocationChanged()
    {
        if (!startupComplete)
        {
            Logger.LogInformation("Home OnLocationChanged skipped: startup not yet complete");
            return;
        }

        await InvokeAsync(async () =>
        {
            Logger.LogInformation("Home OnLocationChanged: resetting cache, hasActiveLocation={HasActive}, lat={Lat}, lng={Lng}",
                hasActiveLocation, activeLat, activeLng);
            ResetTagCache("location_changed");
            if (selectedTag != null)
            {
                await EnsureTagLoadedAsync(selectedTag, "location_changed_selected_tag");
            }

            // Background warm removed to reduce Google API costs — tags reload on next click
        });
    }

    private async void OnDataChanged()
    {
        dataChangedCount++;

        await InvokeAsync(async () =>
        {
            await LoadRecentlyViewed();

            // Check if any cached tags returned empty results. This happens on MAUI after
            // a location change: DiscoverActivitiesAsync returns empty from stale local cache,
            // then background refresh brings real data and fires DataChanged. We retry those
            // empty tags (up to 10 times total) so they pick up the fresh data.
            var emptyTags = cachedActivitiesByTag
                .Where(kvp => kvp.Value.Count == 0)
                .Select(kvp => kvp.Key)
                .ToList();

            if (emptyTags.Count > 0 && _emptyTagRetryCount < 10)
            {
                _emptyTagRetryCount++;
                Logger.LogInformation(
                    "Home OnDataChanged: retry #{Retry}, {EmptyCount} empty tags [{Tags}], selectedTag={SelectedTag}",
                    _emptyTagRetryCount, emptyTags.Count, string.Join(", ", emptyTags), selectedTag ?? "<none>");

                // Remove empty tags from cache so they get re-fetched
                foreach (var tag in emptyTags)
                {
                    cachedActivitiesByTag.Remove(tag);
                }

                // Re-fetch the selected tag immediately so the user sees results
                if (selectedTag != null && emptyTags.Contains(selectedTag))
                {
                    await EnsureTagLoadedAsync(selectedTag, "data_changed_retry_empty", isUserInitiated: false);
                }
            }
            else if (emptyTags.Count > 0)
            {
                Logger.LogWarning(
                    "Home OnDataChanged: {EmptyCount} empty tags but retry limit reached ({Retry}), tags=[{Tags}]",
                    emptyTags.Count, _emptyTagRetryCount, string.Join(", ", emptyTags));
            }
            else
            {
                Logger.LogDebug("Home OnDataChanged: count={Count}, no empty tags, refreshing recently viewed only", dataChangedCount);
            }

            StateHasChanged();
        });
    }

    private async Task LoadRecentlyViewed()
    {
        try
        {
            var ids = await JS.InvokeAsync<string[]>("getRecentlyViewed");
            if (ids != null && ids.Length > 0)
            {
                var list = new List<Activity>();
                foreach (var idStr in ids)
                {
                    if (Guid.TryParse(idStr, out var id))
                    {
                        var activity = await ActivityService.GetActivityAsync(id);
                        if (activity != null)
                        {
                            list.Add(activity);
                        }
                    }
                }
                recentActivities = list;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Unable to load recently viewed activities");
        }
    }

    private IEnumerable<Activity> GetFilteredRecent()
    {
        if (recentActivities == null) return [];
        if (string.IsNullOrWhiteSpace(searchText)) return recentActivities;
        var term = searchText.Trim();
        return recentActivities.Where(a =>
            (a.Name?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (a.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (a.City?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (a.Category?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private async Task OnTagSelected(string tagName)
    {
        Logger.LogInformation("Home tag selected: current={CurrentTag}, requested={RequestedTag}", selectedTag ?? "", tagName);

        if (selectedTag == tagName)
        {
            ClearFilter();
            return;
        }

        selectedTag = tagName;
        var cacheHit = TryApplyCachedTagFilter();
        Logger.LogInformation("Home tag selected: tag={Tag}, cacheHit={CacheHit}, cachedTagCount={CachedCount}",
            tagName, cacheHit, cachedActivitiesByTag.Count);
        if (!cacheHit)
        {
            await EnsureTagLoadedAsync(tagName, "tag_click_cache_miss");
        }

        StateHasChanged();

        // Auto-scroll to filtered results so the user sees the change
        await Task.Yield();
        await JS.InvokeVoidAsync("eval",
            "document.getElementById('filtered-results')?.scrollIntoView({behavior:'smooth', block:'start'})");
    }

    private async Task CheckQuotaStatusAsync()
    {
        try
        {
            var status = await ActivityService.GetQuotaStatusAsync();
            if (status == null) return;

            var items = new[]
            {
                ("Nearby Search", status.NearbySearch),
                ("Place Details", status.PlaceDetails),
                ("Photos", status.Photos),
                ("Geocoding", status.Geocoding)
            };

            var worst = items.MaxBy(x => x.Item2.Percentage);
            if (worst.Item2.Percentage >= 95)
            {
                quotaWarningLevel = "critical";
                quotaWarningMessage = $"Daily API limit nearly reached — discovery may be limited ({worst.Item1}: {worst.Item2.Used}/{worst.Item2.Limit})";
            }
            else if (worst.Item2.Percentage >= 80)
            {
                quotaWarningLevel = "warning";
                quotaWarningMessage = $"API usage: {worst.Item1} at {worst.Item2.Used}/{worst.Item2.Limit} today";
            }

            if (quotaWarningMessage != null)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to check quota status");
        }
    }

    private void ResetTagCache(string trigger)
    {
        var nextGeneration = Interlocked.Increment(ref cacheGeneration);
        cachedActivitiesByTag = new(StringComparer.OrdinalIgnoreCase);
        _emptyTagRetryCount = 0;

        Logger.LogInformation(
            "Home cache reset: generation={Generation}, trigger={Trigger}, hasActiveLocation={HasActiveLocation}, activeLat={Lat}, activeLng={Lng}",
            nextGeneration, trigger, hasActiveLocation, activeLat, activeLng);
    }

    private async Task EnsureTagLoadedAsync(string tagName, string trigger, bool isUserInitiated = true)
    {
        var generation = cacheGeneration;

        if (cachedActivitiesByTag.ContainsKey(tagName))
        {
            Logger.LogInformation("Home tag load skipped: tag={Tag}, trigger={Trigger}, generation={Generation}, reason=cache_hit",
                tagName, trigger, generation);
            TryApplyCachedTagFilter();
            StateHasChanged();
            return;
        }

        if (isUserInitiated)
        {
            isLoadingFiltered = true;
            Logger.LogInformation("Home loading state: isLoadingFiltered=true, tag={Tag}, trigger={Trigger}", tagName, trigger);
            await InvokeAsync(StateHasChanged);
        }

        var loadSw = System.Diagnostics.Stopwatch.StartNew();
        Logger.LogInformation(
            "Home tag load started: tag={Tag}, trigger={Trigger}, generation={Generation}, hasActiveLocation={HasActiveLocation}, activeLat={Lat}, activeLng={Lng}",
            tagName, trigger, generation, hasActiveLocation, activeLat, activeLng);

        try
        {
            List<Activity> matchingActivities;

            if (hasActiveLocation)
            {
                var radiusMeters = (int)(HomeDiscoverRadiusMiles * MetersPerMile);
                var activities = await ActivityService.DiscoverActivitiesAsync(activeLat, activeLng, radiusMeters, tagName);
                matchingActivities = activities
                    .Where(a => GetTagList(a.Category).Contains(tagName, StringComparer.OrdinalIgnoreCase))
                    .OrderBy(a => GetDistanceValue(a))
                    .ThenByDescending(a => a.Rating)
                    .ToList();
            }
            else
            {
                Logger.LogInformation("Home tag load: no active location, falling back to full list for tag={Tag}", tagName);
                var allActivities = await ActivityService.ListActivitiesAsync();
                matchingActivities = allActivities
                    .Where(a => GetTagList(a.Category).Contains(tagName, StringComparer.OrdinalIgnoreCase))
                    .OrderByDescending(a => a.Rating)
                    .ToList();
            }

            if (generation != cacheGeneration)
            {
                Logger.LogWarning(
                    "Home tag load discarded: tag={Tag}, trigger={Trigger}, staleGeneration={Generation}, currentGeneration={CurrentGeneration}, elapsed={Ms}ms",
                    tagName, trigger, generation, cacheGeneration, loadSw.ElapsedMilliseconds);
                return;
            }

            cachedActivitiesByTag[tagName] = matchingActivities;

            var fastImages = matchingActivities.Count(a => !string.IsNullOrWhiteSpace(a.ImageUrl) && a.ImageUrl.Contains("/api/photos?r="));
            var slowImages = matchingActivities.Count(a => !string.IsNullOrWhiteSpace(a.ImageUrl) && a.ImageUrl.Contains("/api/photos/place/"));

            if (matchingActivities.Count == 0)
            {
                Logger.LogWarning(
                    "Home tag load returned EMPTY: tag={Tag}, trigger={Trigger}, generation={Generation}, elapsed={Ms}ms, hasActiveLocation={HasActive}, lat={Lat}, lng={Lng}",
                    tagName, trigger, generation, loadSw.ElapsedMilliseconds, hasActiveLocation, activeLat, activeLng);
            }
            else
            {
                Logger.LogInformation(
                    "Home tag load completed: tag={Tag}, trigger={Trigger}, generation={Generation}, count={Count}, withImages={ImageCount}, fastImages={Fast}, slowImages={Slow}, elapsed={Ms}ms, sampleImages={SampleImages}",
                    tagName,
                    trigger,
                    generation,
                    matchingActivities.Count,
                    matchingActivities.Count(a => !string.IsNullOrWhiteSpace(a.ImageUrl)),
                    fastImages,
                    slowImages,
                    loadSw.ElapsedMilliseconds,
                    string.Join(" | ", matchingActivities.Take(3).Select(a => a.ImageUrl ?? "<null>")));
            }

            TryApplyCachedTagFilter();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Home tag load failed: tag={Tag}, trigger={Trigger}, generation={Generation}, elapsed={Ms}ms",
                tagName, trigger, generation, loadSw.ElapsedMilliseconds);
        }
        finally
        {
            if (isUserInitiated && generation == cacheGeneration)
            {
                isLoadingFiltered = false;
                Logger.LogInformation("Home loading state: isLoadingFiltered=false, tag={Tag}, trigger={Trigger}", tagName, trigger);
                StateHasChanged();
            }
        }
    }

    private bool TryApplyCachedTagFilter()
    {
        if (selectedTag == null)
        {
            filteredActivities = null;
            return true;
        }

        if (!cachedActivitiesByTag.TryGetValue(selectedTag, out var cachedActivities))
        {
            Logger.LogWarning("Home tag cache miss for {Tag}", selectedTag);
            filteredActivities = null;
            return false;
        }

        filteredListVersion++;
        var imageChanges = CountImageChanges(cachedActivities);
        Logger.LogInformation(
            "Home tag applied: tag={Tag}, count={Count}, withImages={ImageCount}, listVersion={Version}, imageChanges={ImageChanges}",
            selectedTag,
            cachedActivities.Count,
            cachedActivities.Count(a => !string.IsNullOrWhiteSpace(a.ImageUrl)),
            filteredListVersion,
            imageChanges);
        filteredActivities = cachedActivities;
        return true;
    }

    private int CountImageChanges(List<Activity> activities)
    {
        var changes = 0;
        var nextRendered = new Dictionary<Guid, string?>();

        foreach (var a in activities)
        {
            nextRendered[a.Id] = a.ImageUrl;
            if (lastRenderedImageUrls.TryGetValue(a.Id, out var prevUrl))
            {
                if (!string.Equals(prevUrl, a.ImageUrl, StringComparison.Ordinal))
                {
                    changes++;
                    Logger.LogWarning(
                        "Home image changed: activity={Id} ({Name}), prev={PrevUrl}, next={NextUrl}",
                        a.Id, a.Name ?? "", prevUrl ?? "<null>", a.ImageUrl ?? "<null>");
                }
            }
        }

        lastRenderedImageUrls = nextRendered;
        return changes;
    }

    private void ClearFilter()
    {
        Logger.LogInformation("Home tag cleared from {Tag}", selectedTag ?? "");
        selectedTag = null;
        filteredActivities = null;
        StateHasChanged();
    }

    private void ViewDetail(Guid id)
    {
        Navigation.NavigateTo($"/activity/{id}");
    }

    private static List<string> GetTagList(string? category)
    {
        if (string.IsNullOrEmpty(category)) return [];
        return category.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private static string GetFirstTagIcon(string? category)
    {
        var tags = GetTagList(category);
        if (tags.Count == 0) return "\ud83d\udccd";
        var first = tags[0];
        return GetTagIcon(first);
    }

    private static string GetTagIcon(string? tagName)
    {
        if (string.IsNullOrWhiteSpace(tagName)) return "\ud83d\udccd";
        var match = tagCards.FirstOrDefault(t => t.Name == tagName);
        return match?.Emoji ?? "\ud83d\udccd";
    }

    private string FormatCost(double cost)
    {
        if (cost == 0) return "Free";
        return $"${cost:F2}";
    }

    private string GetDistance(Activity activity)
    {
        if (!hasActiveLocation) return "?";
        return GetDistanceValue(activity).ToString("0.1");
    }

    private static double ToRad(double deg) => deg * Math.PI / 180.0;

    private double GetDistanceValue(Activity activity)
    {
        if (!hasActiveLocation) return double.MaxValue;

        const double R = 3958.8;
        var dLat = ToRad(activity.Latitude - activeLat);
        var dLng = ToRad(activity.Longitude - activeLng);
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(ToRad(activeLat)) * Math.Cos(ToRad(activity.Latitude)) *
                Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    // ─── Location Popup (kept from original) ───

    private async Task ToggleLocationPopup()
    {
        showLocationPopup = !showLocationPopup;

        if (showLocationPopup && hasLocation && string.IsNullOrEmpty(userAddress))
        {
            try
            {
                userAddress = await ActivityService.ReverseGeocodeAsync(userLat, userLng);
                StateHasChanged();
            }
            catch
            {
                userAddress = "Address unavailable";
            }
        }
    }

    private async Task OnLocationInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyManualLocationAsync();
        }
    }

    private async Task ApplyManualLocationAsync()
    {
        locationError = null;
        var input = (locationInput ?? string.Empty).Trim();
        if (input.Length != 5 || !input.All(char.IsDigit))
        {
            locationError = "Enter a valid 5-digit ZIP code";
            return;
        }

        try
        {
            var lookup = await ActivityService.LookupZipCodeAsync(input);
            if (lookup == null)
            {
                locationError = "ZIP code not found";
                return;
            }

            LocationService.SetManualLocation(lookup.Latitude, lookup.Longitude, lookup.FormattedAddress);
            showLocationPopup = false;
            userAddress = lookup.FormattedAddress;

            Logger.LogInformation("Home manual location set: ZIP={Zip}, lat={Lat}, lng={Lng}, label={Label}",
                input, activeLat, activeLng, lookup.FormattedAddress ?? "");
        }
        catch (Exception ex)
        {
            locationError = "Location lookup failed";
            Logger.LogError(ex, "Home page location lookup failed for {Input}", input);
        }
    }

    private async Task UseCurrentLocation()
    {
        LocationService.ClearManualLocation();
        showLocationPopup = false;
    }

    public void Dispose()
    {
        LocationService.LocationChanged -= OnLocationChanged;
        ActivityService.DataChanged -= OnDataChanged;
    }

    private record TagCardInfo(string Name, string Emoji);
