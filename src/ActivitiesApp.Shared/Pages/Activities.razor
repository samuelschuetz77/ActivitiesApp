@page "/activities"
@using ActivitiesApp.Shared.Models
@using ActivitiesApp.Shared.Services
@using Microsoft.AspNetCore.Components.Web
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject ILogger<Activities> Logger
@inject LocationService LocationService
@implements IDisposable

<div class="activities-page">
    <div class="search-row">
        <div class="search-container search-container-with-toggle">
            <input type="text" class="search-input" placeholder="Search activities..."
                   @bind="searchText" @bind:event="oninput" @bind:after="OnSearchChangedAsync" />
            <button class="filter-toggle-btn @(useFilters ? "active" : "")"
                    @onclick="ToggleUseFilters"
                    title="@(useFilters ? "Filters active - click to search without filters" : "Filters off - click to apply filters")">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
                </svg>
                <span class="filter-toggle-label">@(useFilters ? "Filtered" : "All")</span>
            </button>
        </div>
        <div class="location-icon-wrapper">
            <button class="location-btn @(LocationService.HasActiveLocation ? "active" : "")"
                    @onclick="ToggleLocationPopup"
                    title="Location controls">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/>
                    <path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
                </svg>
            </button>
            @if (showLocationPopup)
            {
                <div class="location-popup">
                    <div class="location-panel-header">
                        <div>
                            <p class="location-panel-title">Location</p>
                            <p class="location-panel-subtitle">@GetLocationSummary()</p>
                        </div>
                        <span class="location-state-pill @(LocationService.HasActiveLocation ? "active" : "inactive")">
                            @(LocationService.HasActiveLocation ? "On" : "Off")
                        </span>
                    </div>

                    <div class="location-actions-grid">
                        <button class="location-action-btn @(LocationService.IsUsingCurrentLocation ? "active" : "")"
                                @onclick="UseCurrentLocationAsync"
                                disabled="@LocationService.IsRefreshing">
                            Use Current Location
                        </button>
                        <button class="location-action-btn @(LocationService.IsLocationDisabled ? "active" : "")"
                                @onclick="DisableLocationAsync">
                            Disable Location
                        </button>
                    </div>

                    <div class="location-manual-card">
                        <label class="location-section-label" for="zip-input">Use a ZIP code</label>
                        <div class="location-popup-edit">
                            <input id="zip-input" class="zip-input" placeholder="Enter ZIP code" maxlength="5"
                                   disabled="@isApplyingManualLocation"
                                   @bind="locationInput" @bind:event="oninput" @onkeyup="OnLocationInputKeyUp" />
                            <button class="zip-btn" disabled="@isApplyingManualLocation" @onclick="ApplyManualLocationAsync">
                                @(isApplyingManualLocation ? "Applying..." : "Apply")
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(manualLocationStatus))
                        {
                            <p class="location-log-meta">@manualLocationStatus</p>
                        }
                        @if (LocationService.HasManualLocation)
                        {
                            <p class="location-manual-active">ZIP override: @LocationService.ManualLocationLabel</p>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(displayAddress))
                    {
                        <div class="location-current-card">
                            <p class="location-section-label">Active location</p>
                            <p class="location-address">@displayAddress</p>
                            @if (LocationService.HasActiveLocation)
                            {
                                <p class="location-coords">@LocationService.ActiveLatitude.ToString("0.0000"), @LocationService.ActiveLongitude.ToString("0.0000")</p>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(uiErrorMessage))
                    {
                        <div class="location-error-card">
                            <p class="location-error-title">Location error</p>
                            <p class="location-error-message">@uiErrorMessage</p>
                            @if (!string.IsNullOrWhiteSpace(LocationService.LastErrorCode))
                            {
                                <p class="location-error-meta">Code: @LocationService.LastErrorCode</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(LocationService.LastDiagnostics))
                            {
                                <p class="location-error-meta">@LocationService.LastDiagnostics</p>
                            }
                        </div>
                    }

                    <div class="location-log-card">
                        <p class="location-section-label">Recent location logs</p>
                        @if (LocationService.RecentEvents.Count == 0)
                        {
                            <p class="location-log-empty">No location events yet.</p>
                        }
                        else
                        {
                            @foreach (var entry in LocationService.RecentEvents)
                            {
                                <div class="location-log-entry">
                                    <p class="location-log-message">@entry.Message</p>
                                    <p class="location-log-meta">
                                        @entry.TimestampUtc.ToLocalTime().ToString("h:mm:ss tt")
                                        @if (!string.IsNullOrWhiteSpace(entry.ErrorCode))
                                        {
                                            <span> | @entry.ErrorCode</span>
                                        }
                                    </p>
                                    @if (!string.IsNullOrWhiteSpace(entry.Details))
                                    {
                                        <p class="location-log-details">@entry.Details</p>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="filter-bar">
        <div class="filter-item">
            <label>Radius</label>
            <select class="filter-select" @bind="selectedRadius" @bind:after="OnRadiusChanged">
                <option value="5">5 mi</option>
                <option value="10">10 mi</option>
                <option value="25">25 mi</option>
                <option value="50">50 mi</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Cost</label>
            <select class="filter-select" @bind="selectedCost" @bind:after="ApplyFilters">
                <option value="">Any</option>
                <option value="free">Free</option>
                <option value="$">$ (Under $15)</option>
                <option value="$$">$$ ($15-$50)</option>
                <option value="$$$">$$$ ($50+)</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Tag</label>
            <select class="filter-select" @bind="selectedCategory" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="Restaurant">Restaurant</option>
                <option value="Fast Food">Fast Food</option>
                <option value="Convenience Store">Convenience Store</option>
                <option value="Attractions">Attractions</option>
                <option value="Outdoors">Outdoors</option>
                <option value="Arts & Culture">Arts & Culture</option>
                <option value="Nightlife">Nightlife</option>
                <option value="Shopping">Shopping</option>
                <option value="Fitness & Sports">Fitness & Sports</option>
                <option value="Wellness & Beauty">Wellness & Beauty</option>
                <option value="Education">Education</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Age Range</label>
            <select class="filter-select" @bind="selectedAgeRange" @bind:after="ApplyFilters">
                <option value="">Any</option>
                <option value="0-12">Kids (0-12)</option>
                <option value="13-17">Teens (13-17)</option>
                <option value="18-25">Young Adults (18-25)</option>
                <option value="26-40">Adults (26-40)</option>
                <option value="41-65">Middle Age (41-65)</option>
                <option value="65-100">Seniors (65+)</option>
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="loading">@statusMessage</div>
        @if (!string.IsNullOrEmpty(statusDetail))
        {
            <div class="status-detail">@statusDetail</div>
        }
    }

    @if ((filteredActivities == null || isLoadingActivities) && string.IsNullOrEmpty(statusMessage))
    {
        <div class="loading">Preparing activity results...</div>
    }
    else if (filteredActivities != null && !filteredActivities.Any())
    {
        <div class="location-error-card">
            <p class="location-error-title">@emptyStateTitle</p>
            <p class="location-error-message">@emptyStateDetail</p>
            @foreach (var reason in emptyStateReasons)
            {
                <p class="location-error-meta">- @reason</p>
            }
        </div>
    }
    else if (filteredActivities != null)
    {
        <div class="cards-grid">
            @foreach (var activity in filteredActivities)
            {
                <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                    <div class="card-image">
                        @if (!string.IsNullOrEmpty(activity.ImageUrl))
                        {
                            <img src="@activity.ImageUrl" alt="@activity.Name"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                            <div class="image-placeholder" style="display:none;">
                                <span>@GetCategoryIcon(activity.Category)</span>
                            </div>
                        }
                        else
                        {
                            <div class="image-placeholder">
                                <span>@GetCategoryIcon(activity.Category)</span>
                            </div>
                        }
                        @{
                            var tags = GetTagList(activity.Category);
                        }
                        @if (tags.Count > 0)
                        {
                            <span class="card-category-badge">@tags[0]</span>
                        }
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">@activity.Name</h3>
                        <div class="card-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starIndex = i;
                                <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                            }
                            <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                        </div>
                        <div class="card-details">
                            <span class="card-cost">@FormatCost(activity.Cost)</span>
                            <span class="card-distance" title="@GetDistanceDebugLabel(activity)">@GetDistance(activity) mi</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Activity>? allActivities;
    private List<Activity>? defaultActivities;
    private List<Activity>? filteredActivities;

    private string searchText = "";
    private bool useFilters = true;
    private int selectedRadius = 10;
    private string selectedCost = "";
    private string selectedCategory = "";
    private string selectedAgeRange = "";
    private string? statusMessage;
    private string? statusDetail;
    private bool isLoadingActivities;
    private bool showLocationPopup;
    private string locationInput = "";
    private string? locationError;
    private string? displayAddress;
    private string? manualLocationStatus;
    private bool isApplyingManualLocation;
    private bool isRemoteSearchLoading;
    private string emptyStateTitle = "No activities matched the current filters.";
    private string emptyStateDetail = "The current result set did not contain anything that survived every filter.";
    private List<string> emptyStateReasons = [];
    private readonly HashSet<string> _distanceDebugKeys = [];
    private string _lastAppliedLocationSignature = "";
    private string? _lastReverseGeocodeSignature;

    private string? uiErrorMessage => locationError ?? LocationService.LastError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        LocationService.LocationChanged += OnLocationChanged;
        ActivityService.DataChanged += OnDataChanged;
        LocationService.StartTracking();

        await RefreshLocationDisplayAsync();
        await LoadActivities(forceReload: true);
    }

    private async void OnLocationChanged()
    {
        await InvokeAsync(async () =>
        {
            await RefreshLocationDisplayAsync();

            if (LocationService.IsRefreshing)
            {
                StateHasChanged();
                return;
            }

            var signature = GetLocationSignature();
            if (!string.Equals(signature, _lastAppliedLocationSignature, StringComparison.Ordinal))
            {
                await LoadActivities(forceReload: true);
            }
            else
            {
                ApplyFilters();
            }
        });
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(async () =>
        {
            defaultActivities = await ActivityService.ListActivitiesAsync();
            if (string.IsNullOrWhiteSpace(searchText))
            {
                allActivities = defaultActivities;
            }
            ApplyFilters();
        });
    }

    private async Task LoadActivities(bool forceReload = false)
    {
        isLoadingActivities = true;
        statusDetail = null;

        try
        {
            _lastAppliedLocationSignature = GetLocationSignature();

            if (LocationService.HasActiveLocation)
            {
                await DiscoverNearby();
            }
            else
            {
                statusMessage = "Loading saved activities from the database...";
                StateHasChanged();
                defaultActivities = await ActivityService.ListActivitiesAsync();
                allActivities = defaultActivities;
                statusMessage = null;
                statusDetail = null;
                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Activities page failed to load activities");
            allActivities = [];
            filteredActivities = [];
            statusMessage = "Failed to load activities.";
            statusDetail = ex.Message;
        }
        finally
        {
            isLoadingActivities = false;
            StateHasChanged();
        }
    }

    private async Task DiscoverNearby()
    {
        statusMessage = "Discovering activities nearby...";
        statusDetail = LocationService.HasManualLocation
            ? $"Using ZIP override: {LocationService.ManualLocationLabel}"
            : "Using your current location.";
        StateHasChanged();

        var radiusMeters = (int)(selectedRadius * 1609.34);
        Logger.LogInformation(
            "Activities page discovering nearby at ({Lat},{Lng}) radius={RadiusMiles}mi source={Source}",
            LocationService.ActiveLatitude,
            LocationService.ActiveLongitude,
            selectedRadius,
            LocationService.HasManualLocation ? "manual" : "current");

        defaultActivities = await ActivityService.DiscoverActivitiesAsync(
            LocationService.ActiveLatitude,
            LocationService.ActiveLongitude,
            radiusMeters);
        allActivities = defaultActivities;

        statusMessage = null;
        statusDetail = null;
        ApplyFilters();
    }

    private async Task OnSearchChangedAsync()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            allActivities = defaultActivities;
            statusMessage = null;
            statusDetail = null;
            ApplyFilters();
            return;
        }

        allActivities = defaultActivities;
        ApplyFilters();
        if (filteredActivities != null && filteredActivities.Count > 0)
        {
            return;
        }

        if (!LocationService.HasActiveLocation)
        {
            ApplyFilters();
            return;
        }

        var term = searchText.Trim();
        if (term.Length < 2)
        {
            ApplyFilters();
            return;
        }

        await RunRemoteSearchAsync(term);
    }

    private async Task RunRemoteSearchAsync(string term)
    {
        try
        {
            isRemoteSearchLoading = true;
            statusMessage = $"Searching for \"{term}\"...";
            statusDetail = "The page is asking the API for keyword matches near the current location.";
            StateHasChanged();

            var radiusMeters = (int)(selectedRadius * 1609.34);
            var results = await ActivityService.SearchActivitiesAsync(
                LocationService.ActiveLatitude,
                LocationService.ActiveLongitude,
                radiusMeters,
                term);

            allActivities = results;
            Logger.LogInformation(
                "Activities page remote search completed: term={Term}, resultCount={ResultCount}, radius={Radius}, activeLat={Lat}, activeLng={Lng}",
                term, results.Count, selectedRadius, LocationService.ActiveLatitude, LocationService.ActiveLongitude);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Activities page remote search failed for {Term}", term);
            statusDetail = ex.Message;
        }
        finally
        {
            isRemoteSearchLoading = false;
            statusMessage = null;
            ApplyFilters();
        }
    }

    private async Task OnRadiusChanged()
    {
        if (LocationService.HasActiveLocation)
        {
            await DiscoverNearby();
        }
        else
        {
            ApplyFilters();
        }
    }

    private void ToggleUseFilters()
    {
        useFilters = !useFilters;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (allActivities == null)
        {
            return;
        }

        var workingSet = allActivities.AsEnumerable();
        var initialCount = workingSet.Count();
        var searchCount = initialCount;
        var costCount = initialCount;
        var categoryCount = initialCount;
        var distanceCount = initialCount;
        var ageCount = initialCount;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var term = searchText.Trim();
            workingSet = workingSet.Where(a =>
                (a.Name?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.City?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Category?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
            searchCount = workingSet.Count();
        }

        if (useFilters && !string.IsNullOrEmpty(selectedCost))
        {
            workingSet = selectedCost switch
            {
                "free" => workingSet.Where(a => a.Cost == 0),
                "$" => workingSet.Where(a => a.Cost >= 0 && a.Cost < 15),
                "$$" => workingSet.Where(a => a.Cost >= 15 && a.Cost <= 50),
                "$$$" => workingSet.Where(a => a.Cost > 50),
                _ => workingSet
            };
            costCount = workingSet.Count();
        }

        if (useFilters && !string.IsNullOrEmpty(selectedCategory))
        {
            workingSet = workingSet.Where(a => HasTag(a.Category, selectedCategory));
            categoryCount = workingSet.Count();
        }

        if (useFilters && LocationService.HasActiveLocation)
        {
            workingSet = workingSet.Where(a => GetDistanceValue(a) <= selectedRadius);
            distanceCount = workingSet.Count();
        }

        if (useFilters && !string.IsNullOrEmpty(selectedAgeRange))
        {
            var parts = selectedAgeRange.Split('-');
            if (parts.Length == 2 && int.TryParse(parts[0], out var minAge) && int.TryParse(parts[1], out var maxAge))
            {
                workingSet = workingSet.Where(a => a.MinAge <= maxAge && a.MaxAge >= minAge);
            }
        }

        filteredActivities = workingSet.ToList();
        ageCount = filteredActivities.Count;
        UpdateEmptyState(initialCount, searchCount, costCount, categoryCount, distanceCount, ageCount);
        LogVisibleDistanceDiagnostics();
        StateHasChanged();
    }

    private void ViewDetail(Guid id)
    {
        Navigation.NavigateTo($"/activity/{id}");
    }

    private string FormatCost(double cost)
    {
        if (cost == 0)
        {
            return "Free";
        }

        return $"${cost:F2}";
    }

    private double GetDistanceValue(Activity activity)
    {
        if (!LocationService.HasActiveLocation)
        {
            return double.MaxValue;
        }

        return GeoMath.HaversineMiles(
            LocationService.ActiveLatitude,
            LocationService.ActiveLongitude,
            activity.Latitude,
            activity.Longitude);
    }

    private string GetDistance(Activity activity) =>
        LocationService.HasActiveLocation ? GetDistanceValue(activity).ToString("0.1") : "?";

    private string GetDistanceDebugLabel(Activity activity)
    {
        if (!LocationService.HasActiveLocation)
        {
            return "No active location";
        }

        var miles = GetDistanceValue(activity);
        return $"from {LocationService.ActiveLatitude:0.0000},{LocationService.ActiveLongitude:0.0000} to {activity.Latitude:0.0000},{activity.Longitude:0.0000} = {miles:0.000} mi";
    }

    private static List<string> GetTagList(string? category)
    {
        if (string.IsNullOrWhiteSpace(category))
        {
            return [];
        }

        return category.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private static bool HasTag(string? category, string tagName) =>
        GetTagList(category).Any(tag => string.Equals(tag, tagName, StringComparison.OrdinalIgnoreCase));

    private static string GetCategoryIcon(string? category)
    {
        var firstTag = GetTagList(category).FirstOrDefault();
        return firstTag switch
        {
            "Restaurant" => "\ud83c\udf7d\ufe0f",
            "Fast Food" => "\ud83c\udf54",
            "Convenience Store" => "\ud83c\udfe0",
            "Attractions" => "\u2b50",
            "Outdoors" => "\ud83c\udf32",
            "Arts & Culture" => "\ud83c\udfa8",
            "Nightlife" => "\ud83c\udf19",
            "Shopping" => "\ud83d\udecd\ufe0f",
            "Fitness & Sports" => "\ud83c\udfcb\ufe0f",
            "Wellness & Beauty" => "\u2728",
            "Education" => "\ud83c\udf93",
            _ => "\ud83d\udccd"
        };
    }

    private async Task ToggleLocationPopup()
    {
        showLocationPopup = !showLocationPopup;
        if (showLocationPopup)
        {
            await RefreshLocationDisplayAsync();
        }
    }

    private async Task RefreshLocationDisplayAsync()
    {
        if (LocationService.HasManualLocation)
        {
            displayAddress = LocationService.ManualLocationLabel;
            return;
        }

        if (!LocationService.HasLocation)
        {
            displayAddress = LocationService.IsTrackingEnabled
                ? "Current location unavailable"
                : "Location is disabled";
            return;
        }

        var signature = $"{LocationService.Latitude:0.0000}:{LocationService.Longitude:0.0000}";
        if (string.Equals(signature, _lastReverseGeocodeSignature, StringComparison.Ordinal) &&
            !string.IsNullOrWhiteSpace(displayAddress))
        {
            return;
        }

        displayAddress = "Looking up current address...";
        _lastReverseGeocodeSignature = signature;

        try
        {
            displayAddress = await ActivityService.ReverseGeocodeAsync(LocationService.Latitude, LocationService.Longitude);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Activities page reverse geocode failed");
            displayAddress = "Current address unavailable";
        }
    }

    private async Task OnLocationInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyManualLocationAsync();
        }
    }

    private async Task ApplyManualLocationAsync()
    {
        locationError = null;
        manualLocationStatus = null;
        var input = (locationInput ?? string.Empty).Trim();
        if (input.Length != 5 || !input.All(char.IsDigit))
        {
            locationError = "Enter a valid 5-digit ZIP code.";
            return;
        }

        try
        {
            isApplyingManualLocation = true;
            manualLocationStatus = $"Looking up ZIP {input}...";
            StateHasChanged();

            var lookup = await ActivityService.LookupZipCodeAsync(input);
            if (lookup == null)
            {
                locationError = "ZIP code not found.";
                manualLocationStatus = $"ZIP {input} did not return a geocoding result.";
                return;
            }

            LocationService.SetManualLocation(lookup.Latitude, lookup.Longitude, lookup.FormattedAddress);
            displayAddress = lookup.FormattedAddress;
            showLocationPopup = true;
            manualLocationStatus = $"ZIP {input} resolved to {lookup.FormattedAddress}.";
            Logger.LogInformation("Activities page manual location set to ZIP {Zip}", input);
            await LoadActivities(forceReload: true);
        }
        catch (Exception ex)
        {
            locationError = ex.Message;
            manualLocationStatus = $"ZIP {input} lookup failed.";
            Logger.LogError(ex, "Activities page location lookup failed for {Input}", input);
        }
        finally
        {
            isApplyingManualLocation = false;
            StateHasChanged();
        }
    }

    private void UpdateEmptyState(int initialCount, int searchCount, int costCount, int categoryCount, int distanceCount, int ageCount)
    {
        if (filteredActivities == null || filteredActivities.Count > 0)
        {
            emptyStateTitle = "No activities matched the current filters.";
            emptyStateDetail = "The current result set did not contain anything that survived every filter.";
            emptyStateReasons = [];
            return;
        }

        emptyStateTitle = "No activities are visible right now.";
        emptyStateDetail = "The page loaded data, but one or more filters reduced the visible cards to zero.";
        emptyStateReasons =
        [
            initialCount == 0 ? "The base activity payload was empty before text filtering even started." : $"The base activity payload contained {initialCount} cards.",
            !string.IsNullOrWhiteSpace(searchText) ? $"Text search \"{searchText.Trim()}\" reduced the set to {searchCount} cards." : "No text search is active.",
            !string.IsNullOrEmpty(selectedCost) ? $"The cost filter reduced the set to {costCount} cards." : "No cost filter is active.",
            !string.IsNullOrEmpty(selectedCategory) ? $"The category filter reduced the set to {categoryCount} cards." : "No category filter is active.",
            LocationService.HasActiveLocation ? $"The {selectedRadius} mile distance filter reduced the set to {distanceCount} cards." : "No active location means no distance filter was applied.",
            !string.IsNullOrEmpty(selectedAgeRange) ? $"The age-range filter reduced the set to {ageCount} cards." : "No age-range filter is active.",
            isRemoteSearchLoading ? "A remote keyword search is still in progress." : "No remote keyword search is running.",
            !string.IsNullOrWhiteSpace(statusDetail) ? $"Last status detail: {statusDetail}" : "No API status detail was captured.",
            "If the text search finds nothing, the earlier nearby-discover payload may have omitted the place before text filtering began.",
            "If distance values look wrong, compare the tooltip on the mileage text to confirm the exact coordinates used."
        ];

        Logger.LogWarning(
            "Activities page empty state: initial={Initial}, search={Search}, cost={Cost}, category={Category}, distance={Distance}, age={Age}, searchText={SearchText}, selectedCategory={SelectedCategory}, radius={Radius}",
            initialCount, searchCount, costCount, categoryCount, distanceCount, ageCount,
            searchText ?? "", selectedCategory ?? "", selectedRadius);
    }

    private void LogVisibleDistanceDiagnostics()
    {
        if (!LocationService.HasActiveLocation || filteredActivities == null)
        {
            return;
        }

        foreach (var activity in filteredActivities.Take(20))
        {
            var miles = GetDistanceValue(activity);
            var key = $"{GetLocationSignature()}|{activity.Id}|{activity.Latitude:0.000000}|{activity.Longitude:0.000000}|{miles:0.000}";
            if (_distanceDebugKeys.Add(key))
            {
                Logger.LogInformation(
                    "Activities page distance snapshot: activityId={ActivityId}, placeId={PlaceId}, name={Name}, city={City}, activeLat={ActiveLat}, activeLng={ActiveLng}, activityLat={ActivityLat}, activityLng={ActivityLng}, miles={Miles}",
                    activity.Id,
                    activity.PlaceId ?? "",
                    activity.Name ?? "",
                    activity.City ?? "",
                    LocationService.ActiveLatitude,
                    LocationService.ActiveLongitude,
                    activity.Latitude,
                    activity.Longitude,
                    miles);
            }
        }
    }

    private async Task UseCurrentLocationAsync()
    {
        locationError = null;
        LocationService.ClearManualLocation();
        await LocationService.EnableTrackingAsync();
        await RefreshLocationDisplayAsync();
        await LoadActivities(forceReload: true);
    }

    private async Task DisableLocationAsync()
    {
        locationError = null;
        LocationService.DisableTracking();
        displayAddress = LocationService.HasManualLocation
            ? LocationService.ManualLocationLabel
            : "Location is disabled";
        await LoadActivities(forceReload: true);
    }

    private string GetLocationSignature()
    {
        if (LocationService.HasManualLocation)
        {
            return $"manual:{LocationService.ManualLatitude:0.0000}:{LocationService.ManualLongitude:0.0000}";
        }

        if (LocationService.IsUsingCurrentLocation)
        {
            return $"current:{LocationService.Latitude:0.0000}:{LocationService.Longitude:0.0000}";
        }

        return "none";
    }

    private string GetLocationSummary()
    {
        if (LocationService.HasManualLocation)
        {
            return "Using your ZIP override.";
        }

        if (LocationService.IsUsingCurrentLocation)
        {
            return "Using your device's current location.";
        }

        if (LocationService.IsRefreshing)
        {
            return "Requesting your current location...";
        }

        if (!string.IsNullOrWhiteSpace(LocationService.LastError))
        {
            return "Current location failed. Check the error details below.";
        }

        return "Location is currently off.";
    }

    public void Dispose()
    {
        LocationService.LocationChanged -= OnLocationChanged;
        ActivityService.DataChanged -= OnDataChanged;
    }
}
