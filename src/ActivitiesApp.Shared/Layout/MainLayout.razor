@inherits LayoutComponentBase
@inject IFormFactor FormFactor

<div class="app-shell @(FormFactor.IsNative ? "native" : "")">
    @if (!FormFactor.IsNative)
    {
        <header class="app-header">
            <a class="app-brand" href="">
                <span class="brand-bold">Activities</span><span class="brand-light">App</span>
            </a>
            <NavMenu />
            <div class="header-right">
                <AuthorizeView>
                    <Authorized>
                        <span class="user-greeting">@context.User.Identity?.Name</span>
                        <a class="auth-btn" href="MicrosoftIdentity/Account/SignOut">Sign Out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="auth-btn" href="MicrosoftIdentity/Account/SignIn">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>
    }

    <main class="app-main">
        <article class="app-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
