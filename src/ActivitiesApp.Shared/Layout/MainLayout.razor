@inherits LayoutComponentBase
@inject IFormFactor FormFactor

<div class="app-shell @(FormFactor.IsNative ? "native" : "")">
    @if (!FormFactor.IsNative)
    {
        <header class="app-header">
            <a class="app-brand" href="">
                <span class="brand-name">ActivitiesApp</span>
            </a>
            <NavMenu />
            <div class="login-display">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-white me-2">Hello, @context.User.Identity?.Name</span>
                        <a class="btn btn-outline-light btn-sm" href="MicrosoftIdentity/Account/SignOut" data-enhance-nav="false">Sign Out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="btn btn-outline-light btn-sm" href="MicrosoftIdentity/Account/SignIn" data-enhance-nav="false">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>
    }

    <main class="app-main">
        <article class="app-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
