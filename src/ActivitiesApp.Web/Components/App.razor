<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="_content/ActivitiesApp.Shared/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/ActivitiesApp.Shared/app.css" />
    <link rel="stylesheet" href="ActivitiesApp.Web.styles.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="_content/ActivitiesApp.Shared/favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.server.js"]"></script>

    <script>
        window.activitiesLocation = {
            getCurrentLocation: async () => {
                const readPermissionState = async () => {
                    if (!navigator.permissions || !navigator.permissions.query) {
                        return null;
                    }

                    try {
                        const permission = await navigator.permissions.query({ name: 'geolocation' });
                        return permission.state || null;
                    } catch {
                        return null;
                    }
                };

                const permissionState = await readPermissionState();
                if (!navigator.geolocation) {
                    return {
                        success: false,
                        errorCode: 'geolocation_unsupported',
                        message: 'This browser does not support geolocation.',
                        permissionState,
                        diagnostics: 'navigator.geolocation is unavailable'
                    };
                }

                return new Promise(resolve => {
                    navigator.geolocation.getCurrentPosition(
                        pos => resolve({
                            success: true,
                            latitude: pos.coords.latitude,
                            longitude: pos.coords.longitude,
                            permissionState: permissionState || 'granted'
                        }),
                        async err => resolve({
                            success: false,
                            errorCode: err.code === 1
                                ? 'permission_denied'
                                : err.code === 2
                                    ? 'position_unavailable'
                                    : err.code === 3
                                        ? 'timeout'
                                        : 'browser_location_failed',
                            message: err.message || 'Unable to get your current location.',
                            permissionState: await readPermissionState(),
                            diagnostics: `code=${err.code}; maximumAge=300000; timeout=8000`
                        }),
                        { enableHighAccuracy: false, timeout: 8000, maximumAge: 300000 }
                    );
                });
            }
        };

        window.addRecentlyViewed = (id) => {
            let items = JSON.parse(localStorage.getItem('recentlyViewed') || '[]');
            items = items.filter(i => i !== id);
            items.unshift(id);
            if (items.length > 3) items = items.slice(0, 3);
            localStorage.setItem('recentlyViewed', JSON.stringify(items));
        };

        window.getRecentlyViewed = () => {
            return JSON.parse(localStorage.getItem('recentlyViewed') || '[]');
        };
    </script>
</body>

</html>
