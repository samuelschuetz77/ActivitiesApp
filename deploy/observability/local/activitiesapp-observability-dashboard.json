      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Counts all error-level logs and error-like messages while excluding warnings. Different series represent different error types, so the panel stays useful even when there are no HTTP 5xx responses.",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name, detected_level) (count_over_time({service_name=~\"activitiesapp-(api|web)\", detected_level=~\"(?i)(error|critical|fatal)\"}[5m]))",
          "legendFormat": "{{service_name}} {{detected_level}}",
          "queryType": "range",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"activitiesapp-(api|web)\"} |~ \"(?i)(exception|failure|failed|panic|error)\" [5m]))",
          "legendFormat": "{{service_name}} message errors",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "All Errors",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "none"
        },
        "overrides": []
      },
