        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"activitiesapp-(api|web)\", detected_level=~\"[Ww][Aa][Rr][Nn].*\"}[5m]))",
          "legendFormat": "{{service_name}} warnings",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Warnings",
      "type": "timeseries"
