      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name, http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=~\"activitiesapp-(api|web)\", http_response_status_code=~\"2..|4..|5..\"}[5m]))",
          "legendFormat": "{{service_name}} {{http_response_status_code}}",
          "range": true,
          "refId": "A"
        }
