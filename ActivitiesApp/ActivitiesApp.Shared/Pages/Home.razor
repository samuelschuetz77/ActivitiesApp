@page "/"
@using ActivitiesApp.Shared.Services
@using ActivitiesApp.Shared.Models
@inject IFormFactor FormFactor
@inject IActivityService ActivityService

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app running on <em>@factor</em> using <em>@platform</em>.

<hr />

<h2>Create a New Activity</h2>

<EditForm Model="@newActivity" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Name:</label>
        <InputText @bind-Value="newActivity.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>City:</label>
        <InputText @bind-Value="newActivity.City" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Description:</label>
        <InputTextArea @bind-Value="newActivity.Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Cost:</label>
        <InputNumber @bind-Value="newActivity.Cost" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Activity Time:</label>
        <InputDate @bind-Value="newActivity.Activitytime" Type="InputDateType.DateTimeLocal" class="form-control" />
    </div>

    <div class="mb-3 row">
        <div class="col">
            <label>Latitude:</label>
            <InputNumber @bind-Value="newActivity.Latitude" class="form-control" />
        </div>
        <div class="col">
            <label>Longitude:</label>
            <InputNumber @bind-Value="newActivity.Longitude" class="form-control" />
        </div>
    </div>

    <div class="mb-3 row">
        <div class="col">
            <label>Min Age:</label>
            <InputNumber @bind-Value="newActivity.MinAge" class="form-control" />
        </div>
        <div class="col">
            <label>Max Age:</label>
            <InputNumber @bind-Value="newActivity.MaxAge" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label>Category:</label>
        <InputSelect @bind-Value="newActivity.Category" class="form-control">
            <option value="">Select a category</option>
            <option value="Outdoors">Outdoors</option>
            <option value="Sports">Sports</option>
            <option value="Arts">Arts</option>
            <option value="Food">Food</option>
            <option value="Music">Music</option>
            <option value="Social">Social</option>
            <option value="Education">Education</option>
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary">Create Activity</button>
</EditForm>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3">@successMessage</div>
}

@code {
    private string factor => FormFactor.GetFormFactor();
    private string platform => FormFactor.GetPlatform();

    private Activity newActivity { get; set; } = new Activity() { Activitytime = DateTime.UtcNow };
    private string? successMessage;

    private async Task HandleValidSubmit()
    {
        var created = await ActivityService.CreateActivityAsync(newActivity);
        successMessage = $"Activity '{created.Name}' in '{created.City}' saved successfully!";

        // Reset the form
        newActivity = new Activity() { Activitytime = DateTime.UtcNow };
    }
}
