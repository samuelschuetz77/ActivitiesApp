@page "/"
@using ActivitiesApp.Shared.Services
@using ActivitiesApp.Shared.Models
@using Microsoft.JSInterop
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject ILogger<Home> Logger

<PageTitle>Home</PageTitle>

<div class="home-page">
    <!-- Location Row -->
    <div class="home-location-row">
        <h1 class="home-title">Home</h1>
        <div class="zip-search-group">
            <input class="zip-input" placeholder="Enter ZIP code" maxlength="5" @bind="zipCode" />
            <button class="zip-btn" @onclick="ApplyZipCodeAsync">Use ZIP</button>
            <button class="zip-btn secondary" @onclick="ClearZipCodeAsync">Use DB</button>
        </div>
    </div>

    <div class="zip-status">
        @if (hasZipLocation)
        {
            <span>Using ZIP <strong>@activeZipCode</strong> near @resolvedLocationLabel</span>
        }
        else
        {
            <span>Using database fallback. Browser location is disabled on Blazor for now.</span>
        }
    </div>

    <!-- Recently Viewed Section -->
    @if (recentActivities != null && recentActivities.Any())
    {
        <div class="home-section">
            <h2 class="home-section-title">Recently Viewed</h2>
            <div class="cards-grid">
                @foreach (var activity in recentActivities)
                {
                    <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(activity.ImageUrl))
                            {
                                <img src="@activity.ImageUrl" alt="@activity.Name" />
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <span>No Image</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(activity.Category))
                            {
                                <span class="card-category-badge">@activity.Category</span>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@activity.Name</h3>
                            <div class="card-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                }
                                <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                            </div>
                            <div class="card-details">
                                <span class="card-cost">@FormatCost(activity.Cost)</span>
                                <span class="card-distance">@GetDistance(activity) mi</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Activities Near You Section -->
    <div class="home-section">
        <h2 class="home-section-title">Activities Near You</h2>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="loading">@statusMessage</div>
            @if (!string.IsNullOrEmpty(statusDetail))
            {
                <div class="status-detail">@statusDetail</div>
            }
        }
        else if (isLoadingNearby || nearbyActivities == null)
        {
            <div class="loading">Preparing activity feed...</div>
        }
        else if (!nearbyActivities.Any())
        {
            <div class="no-results">No nearby activities found.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var activity in nearbyActivities.Take(10))
                {
                    <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(activity.ImageUrl))
                            {
                                <img src="@activity.ImageUrl" alt="@activity.Name" />
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <span>No Image</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(activity.Category))
                            {
                                <span class="card-category-badge">@activity.Category</span>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@activity.Name</h3>
                            <div class="card-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                }
                                <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                            </div>
                            <div class="card-details">
                                <span class="card-cost">@FormatCost(activity.Cost)</span>
                                <span class="card-distance">@GetDistance(activity) mi</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="see-more-container">
                <button class="btn-see-more" @onclick="GoToActivities">See More</button>
            </div>
        }
    </div>
</div>

@code {
    private List<Activity>? recentActivities;
    private List<Activity>? nearbyActivities;
    private string? statusMessage;
    private string? statusDetail;
    private bool isLoadingNearby;
    private string zipCode = "";
    private string? activeZipCode;
    private string? resolvedLocationLabel;
    private double zipLat;
    private double zipLng;
    private bool hasZipLocation => !string.IsNullOrWhiteSpace(activeZipCode);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRecentlyViewed();
            await LoadNearbyActivities();
        }
    }

    private async Task LoadRecentlyViewed()
    {
        try
        {
            var ids = await JS.InvokeAsync<string[]>("getRecentlyViewed");
            if (ids != null && ids.Length > 0)
            {
                var list = new List<Activity>();
                foreach (var idStr in ids)
                {
                    if (Guid.TryParse(idStr, out var id))
                    {
                        var activity = await ActivityService.GetActivityAsync(id);
                        if (activity != null)
                        {
                            list.Add(activity);
                        }
                    }
                }
                recentActivities = list;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Unable to load recently viewed activities");
        }
    }

    private async Task LoadNearbyActivities()
    {
        isLoadingNearby = true;
        statusDetail = null;
        try
        {
            if (hasZipLocation)
            {
                statusMessage = $"Discovering activities near ZIP {activeZipCode}...";
                statusDetail = $"Step 2/2: calling API discovery at {zipLat:0.0000}, {zipLng:0.0000}";
                StateHasChanged();

                var radiusMeters = (int)(10 * 1609.34); // 10 miles
                Logger.LogInformation("Home page discovering nearby activities for ZIP {ZipCode} at ({Lat},{Lng})",
                    activeZipCode, zipLat, zipLng);
                nearbyActivities = await ActivityService.DiscoverActivitiesAsync(zipLat, zipLng, radiusMeters);
                statusMessage = null;
                statusDetail = null;
            }
            else
            {
                statusMessage = "Loading saved activities from the database...";
                statusDetail = "Step 1/1: listing activities without ZIP-based discovery";
                Logger.LogInformation("Home page loading activities from DB fallback without ZIP code");
                nearbyActivities = await ActivityService.ListActivitiesAsync();
                statusMessage = null;
                statusDetail = null;
            }
        }
        catch (Exception ex)
        {
            var api = Configuration["ApiAddress"] ?? "not set";
            Logger.LogError(ex, "Home page failed to load activities from {ApiAddress}", api);
            statusMessage = hasZipLocation
                ? $"ZIP discovery failed for {activeZipCode}."
                : "Database activity load failed.";
            statusDetail = $"API={api}; Error={ex.Message}";
            nearbyActivities = [];
        }
        finally
        {
            isLoadingNearby = false;
            StateHasChanged();
        }
    }

    private void ViewDetail(Guid id)
    {
        Navigation.NavigateTo($"/activity/{id}");
    }

    private void GoToActivities()
    {
        Navigation.NavigateTo("/activities");
    }

    private string FormatCost(double cost)
    {
        if (cost == 0) return "Free";
        return $"${cost:F2}";
    }

    private string GetDistance(Activity activity)
    {
        if (!hasZipLocation) return "?";

        const double R = 3958.8;
        var dLat = ToRad(activity.Latitude - zipLat);
        var dLng = ToRad(activity.Longitude - zipLng);
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(ToRad(zipLat)) * Math.Cos(ToRad(activity.Latitude)) *
                Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return (R * c).ToString("0.1");
    }

    private static double ToRad(double deg) => deg * Math.PI / 180.0;

    private async Task ApplyZipCodeAsync()
    {
        var normalizedZip = (zipCode ?? string.Empty).Trim();
        if (normalizedZip.Length != 5 || !normalizedZip.All(char.IsDigit))
        {
            statusMessage = "ZIP lookup failed.";
            statusDetail = "Enter a 5-digit US ZIP code.";
            return;
        }

        try
        {
            statusMessage = $"Resolving ZIP {normalizedZip}...";
            statusDetail = "Step 1/2: asking Google Geocoding for ZIP coordinates";
            StateHasChanged();

            var zipLookup = await ActivityService.LookupZipCodeAsync(normalizedZip);
            if (zipLookup == null)
            {
                statusMessage = $"ZIP lookup failed for {normalizedZip}.";
                statusDetail = "Google returned no coordinates for that ZIP.";
                return;
            }

            activeZipCode = normalizedZip;
            zipLat = zipLookup.Latitude;
            zipLng = zipLookup.Longitude;
            resolvedLocationLabel = zipLookup.FormattedAddress;

            Logger.LogInformation("Home page resolved ZIP {ZipCode} to ({Lat},{Lng}) {Address}",
                activeZipCode, zipLat, zipLng, resolvedLocationLabel);

            await LoadNearbyActivities();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Home page ZIP lookup failed for {ZipCode}", normalizedZip);
            statusMessage = $"ZIP lookup failed for {normalizedZip}.";
            statusDetail = ex.Message;
        }
    }

    private async Task ClearZipCodeAsync()
    {
        activeZipCode = null;
        resolvedLocationLabel = null;
        zipLat = 0;
        zipLng = 0;
        statusMessage = null;
        statusDetail = null;
        await LoadNearbyActivities();
    }
}
