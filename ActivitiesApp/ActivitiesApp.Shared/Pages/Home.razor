@page "/"
@using ActivitiesApp.Shared.Services
@using ActivitiesApp.Shared.Models
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject ILogger<Home> Logger
@inject LocationService LocationService
@implements IDisposable

<PageTitle>Home</PageTitle>

<div class="home-page">
    <!-- Location Row -->
    <div class="home-location-row">
        <h1 class="home-title">Discover</h1>
        <div class="location-icon-wrapper">
            <button class="location-btn @(hasActiveLocation ? "active" : "")" @onclick="ToggleLocationPopup" title="Your location">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/>
                    <path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
                </svg>
            </button>
            @if (showLocationPopup)
            {
                <div class="location-popup">
                    @if (hasLocation)
                    {
                        @if (!string.IsNullOrEmpty(userAddress))
                        {
                            <p class="location-address">@userAddress</p>
                        }
                        else
                        {
                            <p class="location-address loading-text">Looking up address...</p>
                        }
                        <p class="location-coords">@userLat.ToString("0.0000"), @userLng.ToString("0.0000")</p>
                    }
                    else
                    {
                        <p class="location-address">GPS not available</p>
                    }
                    <div class="location-popup-edit">
                        <input class="zip-input" placeholder="Enter ZIP code" maxlength="5"
                               @bind="locationInput" @bind:event="oninput" @onkeyup="OnLocationInputKeyUp" />
                        <button class="zip-btn" @onclick="ApplyManualLocationAsync">Apply</button>
                    </div>
                    @if (locationError != null)
                    {
                        <p class="location-error" style="color:red;font-size:0.85em;margin:4px 0;">@locationError</p>
                    }
                    @if (hasManualLocation && hasLocation)
                    {
                        <button class="zip-btn" style="margin-top:6px;width:100%;" @onclick="UseCurrentLocation">Use Current Location</button>
                    }
                    @if (hasManualLocation)
                    {
                        <p class="location-override-label">Using: @LocationService.ManualLocationLabel</p>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Recently Viewed Section -->
    @if (recentActivities != null && recentActivities.Any())
    {
        <div class="home-section">
            <h2 class="home-section-title">Recently Viewed</h2>
            <div class="cards-grid">
                @foreach (var activity in recentActivities)
                {
                    <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(activity.ImageUrl))
                            {
                                <img src="@activity.ImageUrl" alt="@activity.Name"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <div class="image-placeholder" style="display:none;">
                                    <span>@GetFirstTagIcon(activity.Category)</span>
                                </div>
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <span>@GetFirstTagIcon(activity.Category)</span>
                                </div>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@activity.Name</h3>
                            <div class="card-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                }
                                <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                            </div>
                            <div class="card-details">
                                <span class="card-cost">@FormatCost(activity.Cost)</span>
                                <span class="card-distance">@GetDistance(activity) mi</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Tag Cards Section -->
    <div class="home-section">
        <h2 class="home-section-title">What are you looking for?</h2>
        <p class="home-section-subtitle">Tap a tag to load places near your current or selected location.</p>
        <div class="tag-cards-grid">
            @foreach (var tag in tagCards)
            {
                <div class="tag-card @(selectedTag == tag.Name ? "selected" : "")"
                     @onclick="() => OnTagSelected(tag.Name)">
                    <span class="tag-card-icon">@tag.Emoji</span>
                    <span class="tag-card-label">@tag.Name</span>
                </div>
            }
        </div>
    </div>

    <!-- Filtered Results Section -->
    @if (selectedTag != null)
    {
        <div class="home-section">
            <div class="filtered-header">
                <h2 class="home-section-title">@selectedTag</h2>
                <button class="clear-filter-btn" @onclick="ClearFilter">Clear</button>
            </div>

            @if (isLoadingFiltered)
            {
                <div class="loading">Searching nearby...</div>
            }
            else if (filteredActivities != null && !filteredActivities.Any())
            {
                <div class="no-results">No @selectedTag activities found nearby.</div>
            }
            else if (filteredActivities != null)
            {
                <div class="cards-grid">
                    @foreach (var activity in filteredActivities)
                    {
                        <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                            <div class="card-image">
                                @if (!string.IsNullOrEmpty(activity.ImageUrl))
                                {
                                    <img src="@activity.ImageUrl" alt="@activity.Name"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div class="image-placeholder" style="display:none;">
                                        <span>@GetTagIcon(selectedTag)</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="image-placeholder">
                                        <span>@GetTagIcon(selectedTag)</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(selectedTag))
                                {
                                    <span class="card-category-badge">@selectedTag</span>
                                }
                            </div>
                            <div class="card-body">
                                <h3 class="card-title">@activity.Name</h3>
                                <div class="card-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starIndex = i;
                                        <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                                    }
                                    <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                                </div>
                                <div class="card-details">
                                    <span class="card-cost">@FormatCost(activity.Cost)</span>
                                    <span class="card-distance">@GetDistance(activity) mi</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    // Tag card definitions matching GooglePlaceTagMapper on the backend
    private static readonly List<TagCardInfo> tagCards =
    [
        new("Food & Drink", "\ud83c\udf7d\ufe0f"),
        new("Attractions", "\u2b50"),
        new("Outdoors", "\ud83c\udf32"),
        new("Arts & Culture", "\ud83c\udfa8"),
        new("Nightlife", "\ud83c\udf19"),
        new("Shopping", "\ud83d\udecd\ufe0f"),
        new("Fitness & Sports", "\ud83c\udfcb\ufe0f"),
        new("Wellness & Beauty", "\u2728"),
        new("Education", "\ud83c\udf93"),
    ];

    private List<Activity>? recentActivities;
    private List<Activity>? filteredActivities;
    private string? selectedTag;
    private bool isLoadingFiltered;
    private int filterRequestVersion;

    // Location popup
    private bool showLocationPopup;
    private string? userAddress;
    private string locationInput = "";
    private string? locationError;

    // GPS from service
    private bool hasLocation => LocationService.HasLocation;
    private double userLat => LocationService.Latitude;
    private double userLng => LocationService.Longitude;

    // Manual + active location from shared singleton
    private bool hasManualLocation => LocationService.HasManualLocation;
    private bool hasActiveLocation => LocationService.HasActiveLocation;
    private double activeLat => LocationService.ActiveLatitude;
    private double activeLng => LocationService.ActiveLongitude;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Logger.LogInformation("Home first render complete");
            LocationService.StartTracking(JS);

            await LoadRecentlyViewed();
        }
    }

    private async Task LoadRecentlyViewed()
    {
        try
        {
            var ids = await JS.InvokeAsync<string[]>("getRecentlyViewed");
            if (ids != null && ids.Length > 0)
            {
                var list = new List<Activity>();
                foreach (var idStr in ids)
                {
                    if (Guid.TryParse(idStr, out var id))
                    {
                        var activity = await ActivityService.GetActivityAsync(id);
                        if (activity != null)
                        {
                            list.Add(activity);
                        }
                    }
                }
                recentActivities = list;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Unable to load recently viewed activities");
        }
    }

    private async Task OnTagSelected(string tagName)
    {
        Logger.LogInformation("Home tag selected: current={CurrentTag}, requested={RequestedTag}", selectedTag ?? "", tagName);

        if (selectedTag == tagName)
        {
            ClearFilter();
            return;
        }

        selectedTag = tagName;
        await LoadFilteredActivities(tagName, "tag_click");
    }

    private async Task LoadFilteredActivities(string tagName, string trigger)
    {
        var requestVersion = Interlocked.Increment(ref filterRequestVersion);
        isLoadingFiltered = true;

        Logger.LogInformation(
            "Home tag load {RequestVersion} started: tag={Tag}, trigger={Trigger}, hasActiveLocation={HasActiveLocation}, activeLat={Lat}, activeLng={Lng}",
            requestVersion, tagName, trigger, hasActiveLocation, activeLat, activeLng);

        await InvokeAsync(StateHasChanged);

        try
        {
            List<Activity> all;
            if (hasActiveLocation)
            {
                var radiusMeters = (int)(10 * 1609.34);
                all = await ActivityService.DiscoverActivitiesAsync(activeLat, activeLng, radiusMeters, tagName);
            }
            else
            {
                all = await ActivityService.ListActivitiesAsync();
            }

            var matchingActivities = all
                .Where(a => GetTagList(a.Category).Contains(tagName))
                .OrderBy(a => hasActiveLocation ? GetDistanceValue(a) : double.MaxValue)
                .ThenByDescending(a => a.Rating)
                .ToList();

            if (requestVersion != filterRequestVersion)
            {
                Logger.LogWarning(
                    "Home tag load {RequestVersion} ignored because a newer request {LatestRequestVersion} already exists",
                    requestVersion, filterRequestVersion);
                return;
            }

            filteredActivities = matchingActivities;

            Logger.LogInformation(
                "Home tag load {RequestVersion} completed: tag={Tag}, fetched={FetchedCount}, matched={MatchedCount}",
                requestVersion, tagName, all.Count, matchingActivities.Count);

            if (matchingActivities.Count > 0)
            {
                Logger.LogInformation(
                    "Home tag load {RequestVersion} sample matches for {Tag}: {ActivityNames}",
                    requestVersion,
                    tagName,
                    string.Join(" | ", matchingActivities.Take(8).Select(a => $"{a.Name} [{a.Category}]")));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Home tag load {RequestVersion} failed for tag {Tag}", requestVersion, tagName);
            filteredActivities = [];
        }
        finally
        {
            if (requestVersion == filterRequestVersion)
            {
                isLoadingFiltered = false;
                StateHasChanged();
            }
        }
    }

    private void ClearFilter()
    {
        Logger.LogInformation("Home tag cleared from {Tag}", selectedTag ?? "");
        selectedTag = null;
        filteredActivities = null;
        StateHasChanged();
    }

    private void ViewDetail(Guid id)
    {
        Navigation.NavigateTo($"/activity/{id}");
    }

    private static List<string> GetTagList(string? category)
    {
        if (string.IsNullOrEmpty(category)) return [];
        return category.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private static string GetFirstTagIcon(string? category)
    {
        var tags = GetTagList(category);
        if (tags.Count == 0) return "\ud83d\udccd";
        var first = tags[0];
        return GetTagIcon(first);
    }

    private static string GetTagIcon(string? tagName)
    {
        if (string.IsNullOrWhiteSpace(tagName)) return "\ud83d\udccd";
        var match = tagCards.FirstOrDefault(t => t.Name == tagName);
        return match?.Emoji ?? "\ud83d\udccd";
    }

    private string FormatCost(double cost)
    {
        if (cost == 0) return "Free";
        return $"${cost:F2}";
    }

    private string GetDistance(Activity activity)
    {
        if (!hasActiveLocation) return "?";
        return GetDistanceValue(activity).ToString("0.1");
    }

    private static double ToRad(double deg) => deg * Math.PI / 180.0;

    private double GetDistanceValue(Activity activity)
    {
        if (!hasActiveLocation) return double.MaxValue;

        const double R = 3958.8;
        var dLat = ToRad(activity.Latitude - activeLat);
        var dLng = ToRad(activity.Longitude - activeLng);
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(ToRad(activeLat)) * Math.Cos(ToRad(activity.Latitude)) *
                Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    // ─── Location Popup (kept from original) ───

    private async Task ToggleLocationPopup()
    {
        showLocationPopup = !showLocationPopup;

        if (showLocationPopup && hasLocation && string.IsNullOrEmpty(userAddress))
        {
            try
            {
                userAddress = await ActivityService.ReverseGeocodeAsync(userLat, userLng);
                StateHasChanged();
            }
            catch
            {
                userAddress = "Address unavailable";
            }
        }
    }

    private async Task OnLocationInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyManualLocationAsync();
        }
    }

    private async Task ApplyManualLocationAsync()
    {
        locationError = null;
        var input = (locationInput ?? string.Empty).Trim();
        if (input.Length != 5 || !input.All(char.IsDigit))
        {
            locationError = "Enter a valid 5-digit ZIP code";
            return;
        }

        try
        {
            var lookup = await ActivityService.LookupZipCodeAsync(input);
            if (lookup == null)
            {
                locationError = "ZIP code not found";
                return;
            }

            LocationService.SetManualLocation(lookup.Latitude, lookup.Longitude, lookup.FormattedAddress);
            showLocationPopup = false;
            userAddress = lookup.FormattedAddress;

            Logger.LogInformation("Home page manual location set to ZIP {Zip} at ({Lat},{Lng})", input, activeLat, activeLng);

            if (selectedTag != null)
            {
                await LoadFilteredActivities(selectedTag, "manual_location_apply");
            }
        }
        catch (Exception ex)
        {
            locationError = "Location lookup failed";
            Logger.LogError(ex, "Home page location lookup failed for {Input}", input);
        }
    }

    private async Task UseCurrentLocation()
    {
        LocationService.ClearManualLocation();
        showLocationPopup = false;

        if (selectedTag != null)
        {
            await LoadFilteredActivities(selectedTag, "use_current_location");
        }
    }

    public void Dispose()
    {
    }

    private record TagCardInfo(string Name, string Emoji);
}
