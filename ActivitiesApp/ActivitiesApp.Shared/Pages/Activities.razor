@page "/activities"
@using ActivitiesApp.Shared.Models
@using ActivitiesApp.Shared.Services
@inject IActivityService ActivityService
@inject NavigationManager Navigation
@inject ILogger<Activities> Logger

<div class="activities-page">
    <div class="search-row">
        <div class="search-container">
            <input type="text" class="search-input" placeholder="Search activities..."
                   @bind="searchText" @bind:event="oninput" @onkeyup="ApplyFilters" />
        </div>
        <div class="zip-search-group">
            <input class="zip-input" placeholder="Enter ZIP code" maxlength="5" @bind="zipCode" />
            <button class="zip-btn" @onclick="ApplyZipCodeAsync">Use ZIP</button>
            <button class="zip-btn secondary" @onclick="ClearZipCodeAsync">Use DB</button>
        </div>
    </div>

    <div class="zip-status">
        @if (hasZipLocation)
        {
            <span>Filtering around ZIP <strong>@activeZipCode</strong> near @resolvedLocationLabel</span>
        }
        else
        {
            <span>Showing database-backed activities without browser location.</span>
        }
    </div>

    <div class="filter-bar">
        <div class="filter-item">
            <label>Radius</label>
            <select class="filter-select" @bind="selectedRadius" @bind:after="OnRadiusChanged">
                <option value="5">5 mi</option>
                <option value="10">10 mi</option>
                <option value="25">25 mi</option>
                <option value="50">50 mi</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Cost</label>
            <select class="filter-select" @bind="selectedCost" @bind:after="ApplyFilters">
                <option value="">Any</option>
                <option value="free">Free</option>
                <option value="$">$ (Under $15)</option>
                <option value="$$">$$ ($15-$50)</option>
                <option value="$$$">$$$ ($50+)</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Category</label>
            <select class="filter-select" @bind="selectedCategory" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="Outdoors">Outdoors</option>
                <option value="Sports">Sports</option>
                <option value="Arts">Arts</option>
                <option value="Food">Food</option>
                <option value="Music">Music</option>
                <option value="Social">Social</option>
                <option value="Education">Education</option>
            </select>
        </div>

        <div class="filter-item">
            <label>Age Range</label>
            <select class="filter-select" @bind="selectedAgeRange" @bind:after="ApplyFilters">
                <option value="">Any</option>
                <option value="0-12">Kids (0-12)</option>
                <option value="13-17">Teens (13-17)</option>
                <option value="18-25">Young Adults (18-25)</option>
                <option value="26-40">Adults (26-40)</option>
                <option value="41-65">Middle Age (41-65)</option>
                <option value="65-100">Seniors (65+)</option>
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="loading">@statusMessage</div>
        @if (!string.IsNullOrEmpty(statusDetail))
        {
            <div class="status-detail">@statusDetail</div>
        }
    }

    @if ((filteredActivities == null || isLoadingActivities) && string.IsNullOrEmpty(statusMessage))
    {
        <div class="loading">Preparing activity results...</div>
    }
    else if (filteredActivities != null && !filteredActivities.Any())
    {
        <div class="no-results">No activities found matching your filters.</div>
    }
    else if (filteredActivities != null)
    {
        <div class="cards-grid">
            @foreach (var activity in filteredActivities)
            {
                <div class="activity-card" @onclick="() => ViewDetail(activity.Id)">
                    <div class="card-image">
                        @if (!string.IsNullOrEmpty(activity.ImageUrl))
                        {
                            <img src="@activity.ImageUrl" alt="@activity.Name" />
                        }
                        else
                        {
                            <div class="image-placeholder">
                                <span>No Image</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(activity.Category))
                        {
                            <span class="card-category-badge">@activity.Category</span>
                        }
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">@activity.Name</h3>
                        <div class="card-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starIndex = i;
                                <span class="star @(starIndex <= activity.Rating ? "filled" : "")">&#9733;</span>
                            }
                            <span class="rating-text">@activity.Rating.ToString("0.0")</span>
                        </div>
                        <div class="card-details">
                            <span class="card-cost">@FormatCost(activity.Cost)</span>
                            <span class="card-distance">@GetDistance(activity) mi</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Activity>? allActivities;
    private List<Activity>? filteredActivities;

    private string searchText = "";
    private int selectedRadius = 10;
    private string selectedCost = "";
    private string selectedCategory = "";
    private string selectedAgeRange = "";
    private string? statusMessage;
    private string? statusDetail;
    private bool isLoadingActivities;
    private string zipCode = "";
    private string? activeZipCode;
    private string? resolvedLocationLabel;
    private double zipLat;
    private double zipLng;
    private bool hasZipLocation => !string.IsNullOrWhiteSpace(activeZipCode);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadActivities();
        }
    }

    private async Task LoadActivities()
    {
        isLoadingActivities = true;
        statusDetail = null;
        try
        {
            if (hasZipLocation)
            {
                await DiscoverNearby();
            }
            else
            {
                statusMessage = "Loading saved activities from the database...";
                statusDetail = "Step 1/1: listing activities without ZIP-based discovery";
                Logger.LogInformation("Activities page loading activities from DB fallback without ZIP code");
                allActivities = await ActivityService.ListActivitiesAsync();
                statusMessage = null;
                statusDetail = null;
                ApplyFilters();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Activities page failed to load activities");
            allActivities = [];
            filteredActivities = [];
            statusMessage = hasZipLocation
                ? $"ZIP discovery failed for {activeZipCode}."
                : "Database activity load failed.";
            statusDetail = ex.Message;
        }
        finally
        {
            isLoadingActivities = false;
            StateHasChanged();
        }
    }

    private async Task DiscoverNearby()
    {
        statusMessage = $"Discovering activities near ZIP {activeZipCode}...";
        statusDetail = $"Step 2/2: calling API discovery at {zipLat:0.0000}, {zipLng:0.0000}";
        StateHasChanged();

        var radiusMeters = (int)(selectedRadius * 1609.34);
        Logger.LogInformation("Activities page discovering nearby activities for ZIP {ZipCode} at ({Lat},{Lng}) radius={RadiusMiles}mi",
            activeZipCode, zipLat, zipLng, selectedRadius);
        allActivities = await ActivityService.DiscoverActivitiesAsync(zipLat, zipLng, radiusMeters);

        statusMessage = null;
        statusDetail = null;
        ApplyFilters();
    }

    private async Task OnRadiusChanged()
    {
        if (hasZipLocation)
        {
            await DiscoverNearby();
        }
        else
        {
            ApplyFilters();
        }
    }

    private void ApplyFilters()
    {
        if (allActivities == null) return;

        var query = allActivities.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var term = searchText.Trim();
            query = query.Where(a =>
                (a.Name?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Description?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.City?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (a.Category?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        if (!string.IsNullOrEmpty(selectedCost))
        {
            query = selectedCost switch
            {
                "free" => query.Where(a => a.Cost == 0),
                "$" => query.Where(a => a.Cost >= 0 && a.Cost < 15),
                "$$" => query.Where(a => a.Cost >= 15 && a.Cost <= 50),
                "$$$" => query.Where(a => a.Cost > 50),
                _ => query
            };
        }

        if (!string.IsNullOrEmpty(selectedCategory))
        {
            query = query.Where(a =>
                string.Equals(a.Category, selectedCategory, StringComparison.OrdinalIgnoreCase));
        }

        if (hasZipLocation)
        {
            query = query.Where(a => GetDistanceValue(a) <= selectedRadius);
        }

        if (!string.IsNullOrEmpty(selectedAgeRange))
        {
            var parts = selectedAgeRange.Split('-');
            if (parts.Length == 2 && int.TryParse(parts[0], out var minAge) && int.TryParse(parts[1], out var maxAge))
            {
                query = query.Where(a => a.MinAge <= maxAge && a.MaxAge >= minAge);
            }
        }

        filteredActivities = query.ToList();
        StateHasChanged();
    }

    private void ViewDetail(Guid id)
    {
        Navigation.NavigateTo($"/activity/{id}");
    }

    private string FormatCost(double cost)
    {
        if (cost == 0) return "Free";
        return $"${cost:F2}";
    }

    private double GetDistanceValue(Activity activity)
    {
        if (!hasZipLocation) return double.MaxValue;

        const double R = 3958.8;
        var dLat = ToRad(activity.Latitude - zipLat);
        var dLng = ToRad(activity.Longitude - zipLng);
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(ToRad(zipLat)) * Math.Cos(ToRad(activity.Latitude)) *
                Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    private string GetDistance(Activity activity) =>
        hasZipLocation ? GetDistanceValue(activity).ToString("0.1") : "?";

    private static double ToRad(double deg) => deg * Math.PI / 180.0;

    private async Task ApplyZipCodeAsync()
    {
        var normalizedZip = (zipCode ?? string.Empty).Trim();
        if (normalizedZip.Length != 5 || !normalizedZip.All(char.IsDigit))
        {
            statusMessage = "ZIP lookup failed.";
            statusDetail = "Enter a 5-digit US ZIP code.";
            return;
        }

        try
        {
            statusMessage = $"Resolving ZIP {normalizedZip}...";
            statusDetail = "Step 1/2: asking Google Geocoding for ZIP coordinates";
            StateHasChanged();

            var zipLookup = await ActivityService.LookupZipCodeAsync(normalizedZip);
            if (zipLookup == null)
            {
                statusMessage = $"ZIP lookup failed for {normalizedZip}.";
                statusDetail = "Google returned no coordinates for that ZIP.";
                return;
            }

            activeZipCode = normalizedZip;
            zipLat = zipLookup.Latitude;
            zipLng = zipLookup.Longitude;
            resolvedLocationLabel = zipLookup.FormattedAddress;

            Logger.LogInformation("Activities page resolved ZIP {ZipCode} to ({Lat},{Lng}) {Address}",
                activeZipCode, zipLat, zipLng, resolvedLocationLabel);

            await LoadActivities();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Activities page ZIP lookup failed for {ZipCode}", normalizedZip);
            statusMessage = $"ZIP lookup failed for {normalizedZip}.";
            statusDetail = ex.Message;
        }
    }

    private async Task ClearZipCodeAsync()
    {
        activeZipCode = null;
        resolvedLocationLabel = null;
        zipLat = 0;
        zipLng = 0;
        statusMessage = null;
        statusDetail = null;
        await LoadActivities();
    }
}
